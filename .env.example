# ==========================================
# 데이터베이스
# ==========================================

# MongoDB 연결 문자열
# 예:
# mongodb://username:password@host:27017/database
MONGODB_URI=

# ==========================================
# 인증 (NextAuth)
# ==========================================

# 애플리케이션 URL
# 로컬: http://localhost:3000
# 운영: https://syncur.com
NEXTAUTH_URL=http://localhost:3000

# 세션 및 JWT 암호화에 사용하는 비밀 키
NEXTAUTH_SECRET=

# ==========================================
# Google OAuth
# ==========================================

# Google OAuth 클라이언트 ID
GOOGLE_CLIENT_ID=

# Google OAuth 클라이언트 시크릿
GOOGLE_CLIENT_SECRET=